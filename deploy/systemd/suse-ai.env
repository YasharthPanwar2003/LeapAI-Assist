# =============================================================================
# suse-ai environment file
# =============================================================================
# Place this file at:
#   System:  /etc/suse-ai/env
#   User:    ~/.config/suse-ai/env
#
# The systemd service loads this via EnvironmentFile=
# =============================================================================

# === LLM Configuration ===
LLM_BASE_URL=http://llm:11434
LLM_MODEL=llama3
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# === Embedding Configuration ===
EMBED_BASE_URL=http://embed:11435
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSIONS=768

# === RAG Configuration ===
RAG_BACKEND=qdrant
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7

# === Application ===
LOG_LEVEL=info
APP_PORT=8090
APP_HOST=0.0.0.0
APP_WORKERS=2

# === Storage ===
DATA_DIR=/var/lib/suse-ai
MODEL_DIR=/var/lib/suse-ai/models
CACHE_DIR=/var/lib/suse-ai/cache

# === Container ===
CONTAINER_IMAGE=localhost/suse-ai:latest
CONTAINER_MEMORY=3g
CONTAINER_CPUS=2

# === Podman (rootless) ===
# NOTE: systemd EnvironmentFile does NOT expand ~ or %h specifiers.
# The actual PODMAN_HOME is set in the unit files via Environment=PODMAN_HOME=%h.
# If you need to customize this, use an absolute path (e.g., /home/youruser/...).
PODMAN_USERNS=keep-id
PODMAN_HOME=/home/<username>/.local/share/containers

# === Ingestion ===
INGEST_MODE=full
INGEST_BATCH_SIZE=100
INGEST_SCHEDULE=03:00

# === Hardware ===
GPU_DEVICE=auto
CUDA_VISIBLE_DEVICES=0
