# =============================================================================
# openSUSE AI Assistant - Containerfile
# Base: opensuse/leap:16 | Python 3.13 | Podman 5.x + Docker compatible
# Build: podman build -t suse-ai:latest -f Containerfile .
#   OR: docker build -t suse-ai:latest -f Containerfile .
# =============================================================================

# Stage 1: builder — system build deps + Python toolchain
FROM opensuse/leap:16 AS builder

ENV ZYPPER_FLAGS="--non-interactive --no-gpg-checks"

RUN zypper ${ZYPPER_FLAGS} refresh && \
    zypper ${ZYPPER_FLAGS} install -y --no-recommends \
        gcc gcc-c++ make cmake \
        python313-devel python313-pip \
        git curl ca-certificates \
    && zypper clean -a

RUN curl -LsSf https://astral.sh/uv/install.sh | CARGO_HOME=/root/.cargo sh
ENV PATH="/root/.cargo/bin:${PATH}"

# Stage 2: python-deps — install Python deps into standalone location
FROM opensuse/leap:16 AS python-deps

COPY --from=builder /root/.cargo/bin/uv /usr/local/bin/uv

ENV ZYPPER_FLAGS="--non-interactive --no-gpg-checks"
RUN zypper ${ZYPPER_FLAGS} install -y --no-recommends \
        python313 python313-base \
    && zypper clean -a

COPY requirements.txt /tmp/requirements.txt
RUN uv pip install --system --no-cache-dir --python python3.13 -r /tmp/requirements.txt

# Stage 3: runtime — minimal image
FROM opensuse/leap:16 AS runtime

LABEL maintainer="openSUSE AI Team"
LABEL description="openSUSE AI Assistant - Local SLM with RAG"
LABEL version="1.0.0"
LABEL org.opensuse.use="ai-assistant"

ENV ZYPPER_FLAGS="--non-interactive --no-gpg-checks"

RUN zypper ${ZYPPER_FLAGS} refresh && \
    zypper ${ZYPPER_FLAGS} install -y --no-recommends \
        python313 python313-base \
        curl ca-certificates gnupg \
    && zypper clean -a

RUN groupadd -r suseai && \
    useradd -r -g suseai -d /home/suseai -s /usr/bin/bash -m suseai

COPY --from=python-deps /usr/lib/python3.13/site-packages /usr/lib/python3.13/site-packages
COPY --from=python-deps /usr/bin/python3.13 /usr/bin/python3.13

ENV PYTHONPATH="/app/src:${PYTHONPATH:-}"
ENV PYTHONUNBUFFERED="1"

COPY src/ /app/src/
COPY pyproject.toml /app/
COPY README.md /app/ 2>/dev/null || true

WORKDIR /app
RUN pip install --no-deps --no-cache-dir -e . 2>/dev/null || true

RUN mkdir -p /data/{models,index,cache/docs,state,logs} && \
    chown -R suseai:suseai /data /app

VOLUME ["/data", "/models"]

USER suseai
WORKDIR /app

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sf http://localhost:8080/v1/models || exit 1

ENTRYPOINT ["python3.13", "-m", "src.core.llm_server"]
CMD ["--model", "/models/LFM2.5-1.2B-Instruct-Q4_K_M.gguf", \
     "--port", "8080", "--threads", "4", "--ctx-size", "8192", "--mmap"]
